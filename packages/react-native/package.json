{
  "name": "@variantlab/react-native",
  "version": "0.1.4",
  "description": "React Native and Expo bindings for variantlab.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./debug": {
      "import": {
        "types": "./dist/debug.d.ts",
        "default": "./dist/debug.js"
      },
      "require": {
        "types": "./dist/debug.d.cts",
        "default": "./dist/debug.cjs"
      }
    },
    "./qr": {
      "import": {
        "types": "./dist/qr.d.ts",
        "default": "./dist/qr.js"
      },
      "require": {
        "types": "./dist/qr.d.cts",
        "default": "./dist/qr.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "pnpm --dir ../.. exec vitest run --project react-native",
    "test:coverage": "pnpm --dir ../.. exec vitest run --coverage --project react-native",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ab-testing",
    "experiments",
    "feature-flags",
    "variants",
    "variantlab",
    "react-native",
    "expo"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Minhaj-Rabby/variantlab.git",
    "directory": "packages/react-native"
  },
  "bugs": {
    "url": "https://github.com/Minhaj-Rabby/variantlab/issues"
  },
  "homepage": "https://github.com/Minhaj-Rabby/variantlab#readme",
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "@variantlab/core": "workspace:*",
    "@variantlab/react": "workspace:*"
  },
  "peerDependencies": {
    "@react-native-async-storage/async-storage": "*",
    "expo-constants": "*",
    "expo-localization": "*",
    "expo-secure-store": "*",
    "react": "^18.2.0 || ^19.0.0",
    "react-native": ">=0.74.0",
    "react-native-mmkv": "*",
    "react-native-safe-area-context": "*",
    "react-native-svg": "*"
  },
  "peerDependenciesMeta": {
    "@react-native-async-storage/async-storage": {
      "optional": true
    },
    "react-native-mmkv": {
      "optional": true
    },
    "expo-secure-store": {
      "optional": true
    },
    "expo-localization": {
      "optional": true
    },
    "expo-constants": {
      "optional": true
    },
    "react-native-safe-area-context": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
