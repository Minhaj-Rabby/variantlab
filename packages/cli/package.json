{
  "name": "@variantlab/cli",
  "version": "0.1.0",
  "description": "Command-line tool for variantlab: init, generate, validate, eval.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "variantlab": "./dist/variantlab.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@variantlab/core": "workspace:*"
  },
  "keywords": [
    "ab-testing",
    "experiments",
    "feature-flags",
    "variants",
    "variantlab",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/variantlab/variantlab.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/variantlab/variantlab/issues"
  },
  "homepage": "https://github.com/variantlab/variantlab#readme",
  "engines": {
    "node": ">=18.17"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  }
}
