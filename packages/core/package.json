{
  "name": "@variantlab/core",
  "version": "0.1.5",
  "description": "The framework-agnostic variantlab engine. Zero dependencies, runs anywhere.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "pnpm --dir ../.. exec vitest run --project core",
    "test:coverage": "pnpm --dir ../.. exec vitest run --coverage --project core",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ab-testing",
    "experiments",
    "feature-flags",
    "variants",
    "variantlab"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Minhaj-Rabby/variantlab.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/Minhaj-Rabby/variantlab/issues"
  },
  "homepage": "https://github.com/Minhaj-Rabby/variantlab#readme",
  "engines": {
    "node": ">=18.17"
  }
}
