{
  "name": "@variantlab/next",
  "version": "0.1.8",
  "description": "Next.js 14 and 15 bindings for variantlab — App Router, Pages Router, and Edge runtime.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client/hooks.d.cts",
        "default": "./dist/client/hooks.cjs"
      },
      "require": {
        "types": "./dist/client/hooks.d.cts",
        "default": "./dist/client/hooks.cjs"
      }
    },
    "./app-router": {
      "import": {
        "types": "./dist/app-router.d.ts",
        "default": "./dist/app-router.js"
      },
      "require": {
        "types": "./dist/app-router.d.cts",
        "default": "./dist/app-router.cjs"
      }
    },
    "./pages-router": {
      "import": {
        "types": "./dist/pages-router.d.ts",
        "default": "./dist/pages-router.js"
      },
      "require": {
        "types": "./dist/pages-router.d.cts",
        "default": "./dist/pages-router.cjs"
      }
    },
    "./debug": {
      "import": {
        "types": "./dist/client/debug.d.ts",
        "default": "./dist/client/debug.js"
      },
      "require": {
        "types": "./dist/client/debug.d.cts",
        "default": "./dist/client/debug.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ab-testing",
    "experiments",
    "feature-flags",
    "variants",
    "variantlab",
    "next",
    "nextjs",
    "ssr",
    "edge"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Minhaj-Rabby/variantlab.git",
    "directory": "packages/next"
  },
  "bugs": {
    "url": "https://github.com/Minhaj-Rabby/variantlab/issues"
  },
  "homepage": "https://github.com/Minhaj-Rabby/variantlab#readme",
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "@variantlab/core": "workspace:*",
    "@variantlab/react": "workspace:*"
  },
  "peerDependencies": {
    "next": "^14.0.0 || ^15.0.0",
    "react": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "next": "^14.2.0",
    "react": "^19.0.0"
  }
}
