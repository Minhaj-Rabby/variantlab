{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@variantlab/core": ["../../packages/core/src/index.ts"],
      "@variantlab/react": ["../../packages/react/src/index.ts"],
      "@variantlab/react-native": ["../../packages/react-native/src/index.ts"],
      "@variantlab/react-native/debug": ["../../packages/react-native/src/debug.ts"],
      "@variantlab/react-native/qr": ["../../packages/react-native/src/qr.ts"]
    }
  },
  "include": ["App.tsx", "src", "experiments.json"]
}
