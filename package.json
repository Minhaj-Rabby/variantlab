{
  "name": "variantlab-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "One config. Every framework. Zero lock-in. Type-safe A/B testing that runs everywhere.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18.17",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "check": "biome check .",
    "fix": "biome check --write .",
    "typecheck": "pnpm -r build && pnpm -r --parallel typecheck",
    "size": "pnpm build && size-limit",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "clean": "pnpm -r --parallel exec rm -rf dist .turbo node_modules/.cache"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@changesets/cli": "^2.27.0",
    "@size-limit/esbuild": "^11.1.0",
    "@size-limit/preset-small-lib": "^11.1.0",
    "@vitest/coverage-v8": "^3.2.0",
    "size-limit": "^11.1.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.0"
  }
}
